---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

import imgManzana from '../assets/images/real_img/Manzana_01.jpeg';
import imgCereza from '../assets/images/real_img/Uvas_01.jpeg';
import imgPalta from '../assets/images/real_img/Palta_01.jpeg';
import imgPasas from '../assets/images/real_img/Mandarinas_02.jpeg';
import imgNueces from '../assets/images/real_img/Nueces_01.jpeg';
import imgMandarina from '../assets/images/real_img/Mandarinas_01.jpeg';
import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';

const deliveryImages = [
  {
    src: imgManzana.src,
    alt: 'Manzanas frescas listas para entrega',
    label: 'Manzanas',
  },
  {
    src: imgCereza.src,
    alt: 'Uvas frescas preparadas para clientes',
    label: 'Uvas',
  },
  {
    src: imgPalta.src,
    alt: 'Paltas frescas preparadas para despacho',
    label: 'Paltas',
  },
  {
    src: imgPasas.src,
    alt: 'Mandarinas preparadas en caja',
    label: 'Mandarinas',
  },
  {
    src: imgNueces.src,
    alt: 'Nueces frescas listas para distribución',
    label: 'Nueces',
  },
  {
    src: imgMandarina.src,
    alt: 'Mandarinas frescas listas para entrega',
    label: 'Mandarinas',
  },
];
---

<section id="entregas" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="text-sm uppercase tracking-widest text-[#2C5E38] font-medium">{t('deliveries.badge')}</span>
      <h2 class="text-4xl md:text-5xl font-serif font-bold text-[#1a3c25] mt-3 mb-6">
        {t('deliveries.title')}
      </h2>
      <p class="max-w-2xl mx-auto text-gray-600 text-lg">
        {t('deliveries.description')}
      </p>
    </div>

    <!-- Carousel -->
    <div class="relative">
      <div class="swiper deliveriesSwiper !pb-12">
        <div class="swiper-wrapper !items-stretch">
          {[...deliveryImages, ...deliveryImages].map((image) => (
            <div class="swiper-slide !h-auto !flex">
              <div class="bg-[#F5F5F0] rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 group h-full flex flex-col w-full border border-black/5">
                <!-- Image Container -->
                <div class="relative h-64 md:h-80 overflow-hidden shrink-0">
                  <img 
                    src={image.src} 
                    alt={image.alt}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                </div>

                <!-- Content -->
                <div class="p-6 flex flex-col flex-1">
                  <p class="text-xs uppercase tracking-[0.2em] text-[#2C5E38] font-bold mb-1">{t('deliveries.slideLabel')}</p>
                  <h3 class="text-xl font-serif font-bold text-[#1a3c25]">{image.label}</h3>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Navigation Buttons (acting as Fade Gradients) -->
      <div class="swiper-button-prev del-prev !left-0 !top-0 !w-24 md:!w-48 !h-[calc(100%-3rem)] !mt-0 !bg-gradient-to-r !from-white !to-transparent z-10 cursor-pointer flex items-center justify-start pl-4 group transition-opacity duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10 text-[#2C5E38] opacity-0 group-hover:opacity-100 transition-all duration-500 ease-out -translate-x-4 group-hover:translate-x-0"><path d="m15 18-6-6 6-6"/></svg>
      </div>
      <div class="swiper-button-next del-next !right-0 !top-0 !w-24 md:!w-48 !h-[calc(100%-3rem)] !mt-0 !bg-gradient-to-l !from-white !to-transparent z-10 cursor-pointer flex items-center justify-end pr-4 group transition-opacity duration-300">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10 text-[#2C5E38] opacity-0 group-hover:opacity-100 transition-all duration-500 ease-out translate-x-4 group-hover:translate-x-0"><path d="m9 18 6-6-6-6"/></svg>
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Autoplay, Navigation, Pagination } from 'swiper/modules';

  const swiper = new Swiper('.deliveriesSwiper', {
    modules: [Autoplay, Navigation, Pagination],
    observer: true,
    observeParents: true,
    slidesPerView: 1.2,
    centeredSlides: true,
    spaceBetween: 20,
    loop: true,
    autoplay: {
      delay: 3500,
      disableOnInteraction: false,
    },
    navigation: {
      nextEl: '.del-next',
      prevEl: '.del-prev',
    },
    breakpoints: {
      640: {
        slidesPerView: 2,
        spaceBetween: 20,
      },
      1024: {
        slidesPerView: 4,
        spaceBetween: 30,
      },
    },
  });
</script>

<style>
  :global(.deliveriesSwiper .swiper-pagination-bullet) {
    background-color: #1a3c25;
    opacity: 0.35;
  }

  :global(.deliveriesSwiper .swiper-pagination-bullet-active) {
    background-color: #1a3c25;
    opacity: 1;
  }

  :global(.deliveriesSwiper .swiper-button-next:after),
  :global(.deliveriesSwiper .swiper-button-prev:after) {
    content: none !important;
  }
</style>
